{
  "name": "@automated-testing/init-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "init-agent": "./src/cli.ts"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "doctor": "tsx src/cli.ts doctor",
    "status": "tsx src/cli.ts status",
    "context": "tsx src/cli.ts context",
    "next": "tsx src/cli.ts next",
    "execute": "tsx src/cli.ts execute",
    "finish": "tsx src/cli.ts finish",
    "merge": "tsx src/cli.ts merge",
    "run-all": "tsx src/cli.ts run-all",
    "run-all:dry-run": "tsx src/cli.ts run-all --dry-run",
    "next:dry-run": "tsx src/cli.ts next --dry-run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
